---
interface Props {
  title:        string;
  description:  string;
  pubDate:      Date;
  slug:         string;
  externalUrl?: string;
}

const { title, description, pubDate, slug, externalUrl } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = externalUrl ?? `${base}/ecrits/${slug}`;
const isExternal = !!externalUrl;

const dateStr = pubDate.toLocaleDateString('fr-FR', {
  day:   'numeric',
  month: 'long',
  year:  'numeric',
});
---

<article class="post-card">
  <p class="meta mb-2">{dateStr}</p>
  <h2 class="font-serif text-[1.15rem] font-medium leading-snug text-ink mb-2 mt-0">
    <a
      href={href}
      class="text-ink"
      style="text-decoration:none"
      target={isExternal ? '_blank' : undefined}
      rel={isExternal ? 'noopener noreferrer' : undefined}
      onmouseover="this.style.textDecoration='underline';this.style.textDecorationColor='#1F3A5F';this.style.textDecorationThickness='1px';this.style.textUnderlineOffset='3px'"
      onmouseout="this.style.textDecoration='none'"
    >
      {title}{isExternal && <span class="text-muted font-sans text-[0.75rem] ml-1">↗</span>}
    </a>
  </h2>
  <p class="font-serif text-[0.95rem] text-muted leading-relaxed m-0">
    {description}
  </p>
</article>

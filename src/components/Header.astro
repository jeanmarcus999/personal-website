---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const nav = [
  { href: `${base}/`,         label: 'Accueil'  },
  { href: `${base}/parcours`, label: 'Parcours' },
  { href: `${base}/ecrits`,   label: 'Écrits'   },
  { href: `${base}/lectures`, label: 'Lectures' },
  { href: `${base}/cerveau`,  label: 'Cerveau'  },
  { href: `${base}/contact`,  label: 'Contact'  },
];

const path = new URL(Astro.request.url).pathname;

function isActive(href: string): boolean {
  const h = href.endsWith('/') ? href : href + '/';
  const p = path.endsWith('/')  ? path  : path  + '/';
  if (href === `${base}/`) return p === h || p === `${base}/`;
  return p.startsWith(h);
}
---

<header class="border-b border-rule">
  <div class="page-wrapper">
    <!--
      Mobile  : nom sur toute la largeur (w-full), nav en dessous (flex-wrap)
      Desktop : nom à gauche, nav à droite sur une seule ligne
    -->
    <nav
      class="flex flex-wrap items-baseline gap-x-7 gap-y-2 py-4 sm:flex-nowrap sm:justify-between sm:py-[1.05rem]"
      aria-label="Navigation principale"
    >
      <a
        href={`${base}/`}
        class="w-full font-serif text-[1rem] font-medium text-ink sm:w-auto"
        style="text-decoration:none"
      >
        Jean Marcus
      </a>

      <ul class="flex flex-wrap items-center gap-x-5 gap-y-1 list-none m-0 p-0 sm:flex-nowrap sm:gap-6">
        {nav.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="nav-item"
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

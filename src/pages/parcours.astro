---
import BaseLayout from '../layouts/BaseLayout.astro';

const formation = [
  {
    years: '2027 à 2028',
    title: 'Stanford University',
    sub:   'Master of Science in Management Science and Engineering',
    desc:  "Année internationale dans le cadre de la deuxième année du Corps des Mines.",
  },
  {
    years: '2026 à 2029',
    title: 'Corps des Mines',
    sub:   'Mines Paris, PSL',
    desc:  "Formation à l'interface de l'ingénierie, de l'administration et de l'économie industrielle. Recruté parmi les dix premiers du classement de sortie de l'École polytechnique.",
  },
  {
    years: '2023 à 2026',
    title: 'École polytechnique',
    sub:   'Cycle ingénieur, Paris-Saclay',
    desc:  "Double majeure mathématiques appliquées et économie. Septième sur 555 étudiants.",
  },
  {
    years: '2021 à 2023',
    title: 'Lycée Sainte-Geneviève',
    sub:   'Classes préparatoires MP, Versailles',
    desc:  "Reçu premier au concours de l'École polytechnique. Également admis à l'École normale supérieure et à CentraleSupélec.",
  },
];

const experience = [
  {
    years: '2026',
    title: 'MIT, Department of Economics',
    sub:   'Assistant de recherche',
    desc:  "Travaux sous la direction d'Esther Duflo. Application de méthodes d'apprentissage automatique à des cadres d'inférence causale, conception de solutions de microcrédit et d'assurance, évaluation de technologies d'intelligence artificielle en santé.",
  },
  {
    years: '2025',
    title: 'Centerview Partners',
    sub:   'Analyste, fusions et acquisitions, Paris',
    desc:  "Études sectorielles fintech, modélisation financière, transaction de quatre milliards de dollars dans le luxe, levée de fonds pour une startup en intelligence artificielle.",
  },
];

const recherche = [
  {
    years: '2025 à 2026',
    title: 'INRIA Sierra',
    sub:   "Sous la direction d'Umut Şimşekli",
    desc:  "Bornes de généralisation dépendantes des données en apprentissage profond. Mesures géométriques de complexité, stabilité algorithmique.",
  },
  {
    years: '2024 à 2025',
    title: 'TotalEnergies',
    sub:   'Sous la direction de Thomas Olivier Léautier',
    desc:  "Économie de la capture du carbone. Modèles technologiques, stratégies de financement, politiques publiques de déploiement.",
  },
];
---

<BaseLayout
  title="Parcours"
  description="Parcours de Jean Marcus : École polytechnique, MIT, Corps des Mines, Stanford."
>
  <div class="page-wrapper">

    <h1 class="page-title">Parcours</h1>

    <div class="prose-body font-serif text-[1rem] sm:text-[1.05rem] leading-[1.8] text-ink mb-12 sm:mb-16">
      <p>
        [Paragraphe biographique à écrire par Jean. Deux à trois phrases reliant formation et sujet intellectuel.]
      </p>
    </div>

    <section class="mb-12 sm:mb-14">
      <span class="section-label">Formation</span>
      <div>
        {formation.map(e => (
          <div class="parcours-row">
            <span class="meta">{e.years}</span>
            <div>
              <p class="font-serif text-[1rem] sm:text-[1.05rem] font-medium text-ink leading-snug mb-1 mt-0">{e.title}</p>
              <p class="meta mb-1">{e.sub}</p>
              <p class="font-serif text-[0.9rem] sm:text-[0.95rem] text-muted leading-relaxed mt-0 mb-0">{e.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-12 sm:mb-14">
      <span class="section-label">Expérience</span>
      <div>
        {experience.map(e => (
          <div class="parcours-row">
            <span class="meta">{e.years}</span>
            <div>
              <p class="font-serif text-[1rem] sm:text-[1.05rem] font-medium text-ink leading-snug mb-1 mt-0">{e.title}</p>
              <p class="meta mb-1">{e.sub}</p>
              <p class="font-serif text-[0.9rem] sm:text-[0.95rem] text-muted leading-relaxed mt-0 mb-0">{e.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-12 sm:mb-14">
      <span class="section-label">Travaux de recherche</span>
      <div>
        {recherche.map(e => (
          <div class="parcours-row">
            <span class="meta">{e.years}</span>
            <div>
              <p class="font-serif text-[1rem] sm:text-[1.05rem] font-medium text-ink leading-snug mb-1 mt-0">{e.title}</p>
              <p class="meta mb-1">{e.sub}</p>
              <p class="font-serif text-[0.9rem] sm:text-[0.95rem] text-muted leading-relaxed mt-0 mb-0">{e.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-14 sm:mb-16">
      <span class="section-label">Centres d'intérêt</span>
      <div class="parcours-row">
        <span class="meta"></span>
        <p class="font-serif text-[1rem] text-ink leading-relaxed mt-0 mb-0">
          Littérature française du XIXe siècle. Droit, en particulier ses intersections
          avec l'économie industrielle. Handball, en compétition dans l'équipe de
          l'École polytechnique. Tennis.
        </p>
      </div>
    </section>

    <div class="mb-6">
      <a href="/cv.pdf" download class="meta" style="color:#1F3A5F;text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px">
        Télécharger le CV en PDF →
      </a>
    </div>

  </div>
</BaseLayout>

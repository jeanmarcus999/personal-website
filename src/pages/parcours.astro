---
import BaseLayout from '../layouts/BaseLayout.astro';

const formation: Entry[] = [
  {
    institution: 'Corps des Mines',
    years:       '2026 à 2029',
    body: `J'y approfondirai les questions d'économie industrielle, de politique publique
      et de financement de long terme, dans le contexte des grandes transformations
      technologiques contemporaines.`,
  },
  {
    institution: 'Stanford University',
    years:       '2027 à 2028',
    sub:         'Master of Science in Management Science and Engineering',
    body: `J'y étudierai l'intelligence artificielle, les systèmes technologiques complexes
      et l'innovation, avec une attention particulière portée à leur diffusion dans les
      entreprises et les économies.`,
  },
  {
    institution: 'École polytechnique',
    years:       '2023 à 2026',
    sub:         'Cycle ingénieur, mathématiques appliquées et économie',
    body: `J'y ai acquis une formation quantitative solide en mathématiques, apprentissage
      automatique et économie, ainsi qu'un intérêt croissant pour les questions de
      technologie, de financement et de transformation économique.`,
  },
  {
    institution: 'Lycée Sainte-Geneviève',
    years:       '2021 à 2023',
    sub:         'Classes préparatoires scientifiques (MP)',
    body: `J'y ai développé un goût durable pour les mathématiques et pour les
      problèmes théoriques exigeants.`,
  },
];

interface Entry {
  institution:  string;
  years:        string;
  sub?:         string;
  supervisor?:  string;
  subUrl?:      string;
  body:         string;
}

const experience: Entry[] = [
  {
    institution: 'MIT, Department of Economics',
    years:       '2026',
    sub:         "Projet de recherche sous la direction d'Esther Duflo",
    supervisor:  'Esther Duflo',
    subUrl:      'https://economics.mit.edu/faculty/eduflo',
    body: `Je travaille sur des sujets situés à l'intersection de l'économie du
      développement et de l'intelligence artificielle. Mes recherches portent notamment
      sur l'utilisation de méthodes d'apprentissage automatique dans des cadres
      d'inférence causale, sur la conception de mécanismes de microcrédit et d'assurance,
      ainsi que sur l'évaluation de technologies d'intelligence artificielle appliquées
      à la santé.`,
  },
  {
    institution: 'Centerview Partners',
    years:       '2025',
    sub:         'Fusions-acquisitions, Paris',
    body: `J'ai participé à des opérations de fusion-acquisition et de levée de fonds
      dans différents secteurs, notamment la fintech, le luxe et l'intelligence
      artificielle. Cette expérience m'a permis d'observer concrètement comment les
      entreprises financent leur croissance, allouent leur capital et adoptent de
      nouvelles technologies.`,
  },
];

const recherche: Entry[] = [
  {
    institution: 'INRIA Sierra',
    years:       '2025 à 2026',
    sub:         "Projet de recherche sous la direction d'Umut Şimşekli",
    supervisor:  'Umut Şimşekli',
    subUrl:      'https://www.di.ens.fr/~simsekli/',
    body: `J'ai travaillé sur des questions théoriques en apprentissage profond. Mes
      recherches portent sur les bornes de généralisation dépendantes des données et sur
      les propriétés géométriques permettant de mieux comprendre pourquoi les modèles
      modernes apprennent et généralisent efficacement.`,
  },
  {
    institution: 'TotalEnergies',
    years:       '2024 à 2025',
    sub:         'Projet de recherche sous la direction de Thomas-Olivier Léautier',
    supervisor:  'Thomas-Olivier Léautier',
    subUrl:      'https://www.tse-fr.eu/people/thomas-olivier-leautier',
    body: `J'ai étudié l'économie des technologies de capture du carbone : leur viabilité
      économique, leurs stratégies de financement et les politiques publiques susceptibles
      d'en favoriser le déploiement. Cette expérience a renforcé mon intérêt pour les
      mécanismes permettant de financer les transformations technologiques de long terme.`,
  },
];
---

<BaseLayout
  title="Parcours"
  description="Parcours de Jean Marcus : École polytechnique, MIT, Corps des Mines, Stanford."
>
  <div class="page-wrapper">

    <h1 class="page-title">Parcours</h1>

    <!-- Formation -->
    <section class="mb-12 sm:mb-14">
      <span class="section-label">Formation</span>
      {formation.map(e => (
        <div class="cv-entry">
          <div class="flex items-baseline justify-between flex-wrap gap-x-4 gap-y-0 mb-1">
            <h2 class="font-serif text-[1.05rem] font-medium text-ink m-0 leading-snug">
              {e.institution}
            </h2>
            <span class="meta flex-shrink-0">{e.years}</span>
          </div>
          {e.sub && (
            <p class="meta mb-2" set:html={
              e.supervisor && e.subUrl
                ? e.sub.replace(
                    e.supervisor,
                    `<a href="${e.subUrl}" target="_blank" rel="noopener noreferrer" style="color:var(--color-accent);text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px">${e.supervisor}</a>`
                  )
                : e.sub
            } />
          )}
          <p class="font-serif text-[0.95rem] text-muted leading-[1.75] prose-justified mt-1 mb-0">
            {e.body}
          </p>
        </div>
      ))}
    </section>

    <!-- Expériences -->
    <section class="mb-12 sm:mb-14">
      <span class="section-label">Expériences</span>
      {experience.map(e => (
        <div class="cv-entry">
          <div class="flex items-baseline justify-between flex-wrap gap-x-4 gap-y-0 mb-1">
            <h2 class="font-serif text-[1.05rem] font-medium text-ink m-0 leading-snug">
              {e.institution}
            </h2>
            <span class="meta flex-shrink-0">{e.years}</span>
          </div>
          {e.sub && (
            <p class="meta mb-2" set:html={
              e.supervisor && e.subUrl
                ? e.sub.replace(
                    e.supervisor,
                    `<a href="${e.subUrl}" target="_blank" rel="noopener noreferrer" style="color:var(--color-accent);text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px">${e.supervisor}</a>`
                  )
                : e.sub
            } />
          )}
          <p class="font-serif text-[0.95rem] text-muted leading-[1.75] prose-justified mt-1 mb-0">
            {e.body}
          </p>
        </div>
      ))}
    </section>

    <!-- Recherche -->
    <section class="mb-12 sm:mb-14">
      <span class="section-label">Recherche</span>
      {recherche.map(e => (
        <div class="cv-entry">
          <div class="flex items-baseline justify-between flex-wrap gap-x-4 gap-y-0 mb-1">
            <h2 class="font-serif text-[1.05rem] font-medium text-ink m-0 leading-snug">
              {e.institution}
            </h2>
            <span class="meta flex-shrink-0">{e.years}</span>
          </div>
          {e.sub && (
            <p class="meta mb-2" set:html={
              e.supervisor && e.subUrl
                ? e.sub.replace(
                    e.supervisor,
                    `<a href="${e.subUrl}" target="_blank" rel="noopener noreferrer" style="color:var(--color-accent);text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px">${e.supervisor}</a>`
                  )
                : e.sub
            } />
          )}
          <p class="font-serif text-[0.95rem] text-muted leading-[1.75] prose-justified mt-1 mb-0">
            {e.body}
          </p>
        </div>
      ))}
    </section>

    <!-- Centres d'intérêt -->
    <section class="mb-14 sm:mb-16">
      <span class="section-label">Centres d'intérêt</span>
      <div class="cv-entry">
        <p class="font-serif text-[0.95rem] text-ink leading-[1.75] prose-justified mt-0 mb-0">
          Littérature française du XIXe siècle. Droit, en particulier ses intersections
          avec l'économie industrielle. Handball, en compétition dans l'équipe de
          l'École polytechnique. Tennis.
        </p>
      </div>
    </section>

    <div class="mb-8">
      <a
        href="/cv.pdf"
        download
        class="meta"
        style="color:#1F3A5F;text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px"
      >
        Télécharger le CV en PDF →
      </a>
    </div>

  </div>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const recent = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  description="Financement et déploiement des technologies stratégiques en Europe. École polytechnique, MIT, Corps des Mines."
>
  <div class="page-wrapper">

    <section class="pb-16 sm:pb-20 md:pb-24">
      <h1 class="page-title">Jean Marcus</h1>
      <p class="font-sans text-[0.82rem] text-muted tracking-[0.04em] uppercase mb-8 sm:mb-10">
        Financement et déploiement des technologies stratégiques en Europe.
      </p>
      <div class="prose-body font-serif text-[1rem] sm:text-[1.05rem] leading-[1.8] text-ink space-y-4">
        <p>
          Élève ingénieur à l'École polytechnique. Internat de recherche en économie
          au MIT sous la direction d'Esther Duflo. J'entre au Corps des Mines en
          septembre 2026 et rejoindrai Stanford en 2027 pour un Master of Science
          in Management Science and Engineering.
        </p>
        <p>
          Mon sujet est celui du déploiement. Les modèles fondationnaux d'intelligence
          artificielle naissent aux États-Unis et en Chine ; ce qui reste ouvert en
          Europe, c'est leur industrialisation, leur financement, leur intégration au
          tissu productif. À quelles conditions de capital, de régulation et
          d'organisation industrielle un continent peut-il absorber à grande échelle
          les technologies qu'il ne produit pas ? Cette question structure mes travaux.
        </p>
        <p>
          En arrière-plan, des intérêts plus larges : économie politique de la
          souveraineté, histoire industrielle européenne, littérature française
          du XIXe siècle.
        </p>
      </div>
    </section>

    <section class="mb-16 sm:mb-20">
      <span class="section-label">Derniers écrits</span>
      <div>
        {recent.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id}
          />
        ))}
      </div>
      <div class="mt-5">
        <a
          href={`${base}/ecrits`}
          class="meta"
          style="color:#1F3A5F;text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px"
        >
          Tous les écrits →
        </a>
      </div>
    </section>

    <section class="mb-6">
      <span class="section-label">Contact</span>
      <div class="pt-4 space-y-2">
        <p class="meta">
          Email :&nbsp;
          <a href="mailto:jean.marcus@icloud.com" style="color:#1F3A5F;text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px">
            jean.marcus@icloud.com
          </a>
        </p>
        <p class="meta">
          LinkedIn :&nbsp;
          <a href="https://linkedin.com/in/jean-marcus" target="_blank" rel="noopener noreferrer" style="color:#1F3A5F;text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px">
            linkedin.com/in/jean-marcus
          </a>
        </p>
      </div>
    </section>

  </div>
</BaseLayout>

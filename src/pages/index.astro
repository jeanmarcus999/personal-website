---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const recent = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const lk = (href: string, text: string, external = true) =>
  `<a href="${href}"${external ? ' target="_blank" rel="noopener noreferrer"' : ''}
     style="color:#1F3A5F;text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px"
  >${text}</a>`;
---

<BaseLayout
  description="Économie de l'adoption technologique, financement de long terme, action publique. École polytechnique, MIT, Corps des Mines, Stanford."
>
  <div class="page-wrapper">

    <section class="pb-16 sm:pb-20 md:pb-24">
      <h1 class="page-title">Jean Marcus</h1>

      <div class="prose-body font-serif text-[1rem] sm:text-[1.05rem] leading-[1.8] text-ink prose-justified space-y-4">
        <p>
          Je m'intéresse à la manière dont les sociétés adoptent les nouvelles
          technologies et se transforment à long terme. Plus précisément, trois
          questions retiennent mon attention : comment les entreprises financent
          l'adoption de technologies nouvelles, comment les États créent les
          conditions de cette adoption, et comment l'épargne et les marchés de
          capitaux soutiennent les investissements de long terme nécessaires à
          ces transformations.
        </p>
        <p>
          J'aime discuter de ces sujets, confronter des idées et travailler sur
          des problèmes complexes, à l'intersection de l'économie, de la technologie
          et de l'action publique.
        </p>
        <p>
          Ces questions ne sont pas nouvelles, mais elles prennent aujourd'hui une
          importance particulière, à mesure que l'intelligence artificielle, la
          transition énergétique et les transformations géopolitiques redessinent
          les économies contemporaines.
        </p>
        <p set:html={`Je rejoindrai le ${lk('https://www.mines-paristech.fr', 'Corps des Mines')} en
          septembre 2026, puis ${lk('https://msande.stanford.edu', 'Stanford')} en 2027 pour un
          Master in Management Science and Engineering. Auparavant, j'ai étudié les
          mathématiques appliquées et l'économie à
          l'${lk('https://www.polytechnique.edu', 'École polytechnique')}. J'ai travaillé
          en fusions-acquisitions chez
          ${lk('https://www.centerviewpartners.com', 'Centerview Partners')} et effectué
          des travaux de recherche en économie au
          ${lk('https://economics.mit.edu', 'MIT')}, au sein du laboratoire
          d'${lk('https://economics.mit.edu/faculty/eduflo', 'Esther Duflo')}.`}
        />
        <p set:html={`J'écris également des ${lk('/ecrits', 'articles et des notes', false)} sur
          des sujets variés, du deep learning à l'économie de la transition
          écologique en Europe.`}
        />
      </div>
    </section>

    <section class="mb-16 sm:mb-20">
      <span class="section-label">Derniers écrits</span>
      <div>
        {recent.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id}
          />
        ))}
      </div>
      <div class="mt-5">
        <a
          href={`${base}/ecrits`}
          class="meta"
          style="color:#1F3A5F;text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px"
        >
          Tous les écrits →
        </a>
      </div>
    </section>

    <section class="mb-6">
      <span class="section-label">Contact</span>
      <div class="pt-4 space-y-2">
        <p class="meta">
          Email :&nbsp;
          <a href="mailto:jean.marcus@icloud.com" style="color:#1F3A5F;text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px">
            jean.marcus@icloud.com
          </a>
        </p>
        <p class="meta">
          LinkedIn :&nbsp;
          <a href="https://linkedin.com/in/jean-marcus" target="_blank" rel="noopener noreferrer" style="color:#1F3A5F;text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px">
            linkedin.com/in/jean-marcus
          </a>
        </p>
      </div>
    </section>

  </div>
</BaseLayout>

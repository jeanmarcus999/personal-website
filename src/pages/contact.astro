---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Contacter Jean Marcus.">
  <div class="page-wrapper">
    <h1 class="page-title">Contact</h1>
    <div class="prose-body font-serif text-[1rem] sm:text-[1.05rem] leading-[1.8] text-ink prose-justified mb-10 sm:mb-12">
      <p>
        Je suis toujours heureux d'échanger avec des personnes intéressées par
        l'économie, la technologie, les politiques publiques ou tout autre sujet.
        N'hésitez pas à me contacter.
      </p>
    </div>
    <div class="space-y-3">
      <p class="meta">
        Email :&nbsp;
        <a href="mailto:jean.marcus@icloud.com" style="color:#1F3A5F;text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px">
          jean.marcus@icloud.com
        </a>
      </p>
      <p class="meta">
        LinkedIn :&nbsp;
        <a href="https://linkedin.com/in/jean-marcus" target="_blank" rel="noopener noreferrer" style="color:#1F3A5F;text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px">
          linkedin.com/in/jean-marcus
        </a>
      </p>
    </div>
  </div>
</BaseLayout>

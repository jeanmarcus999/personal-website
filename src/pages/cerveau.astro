---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<style is:global>
  html:has(#brain-root) {
    background: #0b0b0b;
  }
  html:has(#brain-root) header {
    background: #FBFAF7;
    border-color: #E8E5DD;
  }
  html:has(#brain-root) header a,
  html:has(#brain-root) header nav a {
    color: #1A1A1A;
  }

  /* Panel body content — injecté via innerHTML, le CSS scopé ne s'applique pas */
  #panel-body p.desc {
    font-family: "Source Serif 4 Variable", Georgia, serif;
    font-size: 0.88rem;
    color: #d0d0d0;
    line-height: 1.75;
    margin: 0 0 1.2rem;
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
  }
  #panel-body .cat {
    display: block;
    font-family: "Inter Variable", system-ui, sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #777;
    padding-bottom: 0.45rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    margin: 1.4rem 0 0.6rem;
  }
  #panel-body ul {
    list-style: none;
    margin: 0; padding: 0;
  }
  #panel-body li {
    font-family: "Inter Variable", system-ui, sans-serif;
    font-size: 0.79rem;
    color: #c8c8c8;
    padding: 0.28rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    line-height: 1.5;
  }
  #panel-body li::before {
    content: '·';
    color: #666;
    margin-right: 0.55rem;
  }
  #panel-body em {
    font-style: italic;
    color: inherit;
  }
</style>

<BaseLayout
  title="Cerveau"
  description="Carte des idées, influences intellectuelles et questions ouvertes de Jean Marcus."
>
  <div id="brain-root">
    <canvas id="brain-canvas"></canvas>

    <!-- Panel latéral -->
    <aside id="side-panel" aria-hidden="true">
      <div id="panel-hd">
        <h2 id="panel-title"></h2>
        <button id="panel-close" aria-label="Fermer">✕</button>
      </div>
      <div id="panel-body"></div>
    </aside>

    <!-- Toolbar bas gauche -->
    <div id="toolbar">
      <button id="btn-thought">Pensée aléatoire</button>
      <button id="btn-timeline">Chronologie</button>
    </div>

    <!-- Pensée aléatoire -->
    <div id="thought-box" hidden>
      <p id="thought-text"></p>
    </div>

    <!-- Timeline -->
    <div id="timeline-bar" hidden>
      <div id="tl-info">
        <span id="tl-year">2021</span>
        <span id="tl-label">Mathématiques</span>
      </div>
      <div id="tl-controls">
        <input id="tl-slider" type="range" min="2021" max="2027" value="2021" step="1">
        <button id="tl-play" title="Lecture automatique">▶</button>
      </div>
    </div>

    <!-- Hint -->
    <p id="brain-hint">Cliquez sur un nœud · Défilez pour zoomer</p>
  </div>
</BaseLayout>

<style>
  #brain-root {
    position: relative;
    width: 100%;
    background: #0b0b0b;
    overflow: hidden;
  }

  #brain-canvas {
    display: block;
    cursor: grab;
  }
  #brain-canvas:active { cursor: grabbing; }

  /* ── Side panel ────────────────────────────────────────── */
  #side-panel {
    position: absolute;
    top: 0; right: 0;
    width: min(360px, 88vw);
    height: 100%;
    background: rgba(8,8,8,0.97);
    border-left: 1px solid rgba(255,255,255,0.07);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    transform: translateX(101%);
    transition: transform 0.32s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    overflow-y: auto;
    z-index: 20;
    scrollbar-width: thin;
    scrollbar-color: #2a2a2a transparent;
  }
  #side-panel.open {
    transform: translateX(0);
  }

  #panel-hd {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.75rem 1.5rem 1.1rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    position: sticky;
    top: 0;
    background: rgba(8,8,8,0.97);
  }

  #panel-title {
    font-family: "Source Serif 4 Variable", Georgia, serif;
    font-size: 1.05rem;
    font-weight: 500;
    color: #e0e0e0;
    margin: 0;
    line-height: 1.35;
  }

  #panel-close {
    background: none;
    border: none;
    color: #444;
    cursor: pointer;
    font-size: 0.95rem;
    padding: 0.15rem 0.35rem;
    line-height: 1;
    transition: color 0.15s;
    flex-shrink: 0;
    font-family: system-ui;
  }
  #panel-close:hover { color: #999; }

  #panel-body {
    padding: 1.25rem 1.5rem 2.5rem;
  }

  #panel-body p.desc {
    font-family: "Source Serif 4 Variable", Georgia, serif;
    font-size: 0.88rem;
    color: #c8c8c8;
    line-height: 1.75;
    margin: 0 0 1.2rem;
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
  }

  #panel-body .cat {
    display: block;
    font-family: "Inter Variable", system-ui, sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #666;
    padding-bottom: 0.45rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    margin: 1.4rem 0 0.6rem;
  }

  #panel-body ul {
    list-style: none;
    margin: 0; padding: 0;
  }
  #panel-body li {
    font-family: "Inter Variable", system-ui, sans-serif;
    font-size: 0.79rem;
    color: #c8c8c8;
    padding: 0.28rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    line-height: 1.5;
  }
  #panel-body li::before {
    content: '·';
    color: #555;
    margin-right: 0.55rem;
  }

  /* ── Toolbar ────────────────────────────────────────────── */
  #toolbar {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
    display: flex;
    gap: 0.5rem;
    z-index: 10;
  }
  #toolbar button {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.15);
    color: #888;
    cursor: pointer;
    font-family: "Inter Variable", system-ui, sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 0.42rem 0.85rem;
    transition: all 0.15s;
    line-height: 1;
  }
  #toolbar button:hover {
    background: rgba(255,255,255,0.07);
    color: #aaa;
    border-color: rgba(255,255,255,0.18);
  }
  #toolbar button.active {
    color: #ccc;
    border-color: rgba(255,255,255,0.25);
    background: rgba(255,255,255,0.08);
  }

  /* ── Random thought ─────────────────────────────────────── */
  #thought-box {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: min(500px, 82vw);
    background: rgba(6,6,6,0.93);
    border: 1px solid rgba(255,255,255,0.07);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    padding: 2rem 2.2rem;
    z-index: 30;
    cursor: pointer;
  }
  #thought-text {
    font-family: "Source Serif 4 Variable", Georgia, serif;
    font-style: italic;
    font-size: 1rem;
    color: #b0b0b0;
    line-height: 1.8;
    margin: 0;
    text-align: center;
  }

  /* ── Timeline ───────────────────────────────────────────── */
  #timeline-bar {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    background: rgba(8,8,8,0.92);
    border: 1px solid rgba(255,255,255,0.12);
    padding: 0.85rem 1.1rem;
    z-index: 10;
    backdrop-filter: blur(12px);
    min-width: 220px;
  }
  #tl-info {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
  }
  #tl-year {
    font-family: "Inter Variable", system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #ccc;
  }
  #tl-label {
    font-family: "Inter Variable", system-ui, sans-serif;
    font-size: 0.68rem;
    color: #666;
    letter-spacing: 0.02em;
  }
  #tl-controls {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  #tl-slider {
    -webkit-appearance: none;
    appearance: none;
    flex: 1;
    height: 2px;
    background: rgba(255,255,255,0.12);
    outline: none;
    cursor: pointer;
  }
  #tl-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 10px; height: 10px;
    background: #ccc;
    border-radius: 50%;
  }
  #tl-slider::-moz-range-thumb {
    width: 10px; height: 10px;
    background: #ccc;
    border-radius: 50%;
    border: none;
  }
  #tl-play {
    background: none;
    border: none;
    color: #666;
    cursor: pointer;
    font-size: 0.7rem;
    padding: 0.1rem 0.25rem;
    transition: color 0.15s;
    line-height: 1;
  }
  #tl-play:hover { color: #ccc; }

  /* ── Hint ───────────────────────────────────────────────── */
  #brain-hint {
    position: absolute;
    top: 1rem; left: 50%;
    transform: translateX(-50%);
    font-family: "Inter Variable", system-ui, sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.09em;
    color: rgba(255,255,255,0.25);
    text-transform: uppercase;
    pointer-events: none;
    white-space: nowrap;
    margin: 0;
  }
</style>

<script>
import {
  COLORS, L1_ANGLES, NODE_DEFS, LINK_DEFS, CONTENT,
  THOUGHTS, TL_YEAR, TL_LABEL,
} from '../data/brain.ts';

// ── HELPERS ────────────────────────────────────────────────────
function hexAlpha(hex: string, a: number): string {
  const r = parseInt(hex.slice(1,3),16);
  const g = parseInt(hex.slice(3,5),16);
  const b = parseInt(hex.slice(5,7),16);
  return `rgba(${r},${g},${b},${a})`;
}

// ── DATA (legacy — now in brain.ts) ──────────────────────────

// (data imported from brain.ts)

// ── SIMULATION STATE ─────────────────────────────────────────

interface SimNode extends NodeDef {
  x: number; y: number;
  vx: number; vy: number;
  fx?: number; fy?: number;
}

interface SimLink {
  source: SimNode; target: SimNode;
  dist: number; w: number;
}

const nodes: SimNode[] = NODE_DEFS.map(n => ({ ...n, x: 0, y: 0, vx: 0, vy: 0 }));
const nodeById = new Map(nodes.map(n => [n.id, n]));

const links: SimLink[] = LINK_DEFS.map(l => ({
  source: nodeById.get(l.source)!,
  target: nodeById.get(l.target)!,
  dist: l.dist ?? 120,
  w: l.w ?? 0.35,
})).filter(l => l.source && l.target);

// Adjacency set for isConnected check
const adjSet = new Set(links.flatMap(l => [`${l.source.id}>${l.target.id}`, `${l.target.id}>${l.source.id}`]));
const isConnected = (a: SimNode, b: SimNode) =>
  adjSet.has(`${a.id}>${b.id}`) || adjSet.has(`${b.id}>${a.id}`);

// Node sizing (color comes from COLORS per domain)
interface NStyle { r: number; ringW: number; fs: number; fw: string }
const NSTYLE: Record<string, NStyle> = {
  root: { r: 15, ringW: 1.2, fs: 12, fw: '600' },
  l1:   { r: 8,  ringW: 0.8, fs: 10, fw: '500' },
  l2:   { r: 4,  ringW: 0.6, fs: 9,  fw: '400' },
};

function domainOf(n: SimNode): string {
  return n.type === 'root' ? 'root' : n.type === 'l1' ? n.id : (n.parent ?? 'root');
}
function nodeColor(n: SimNode): string { return COLORS[domainOf(n)] ?? '#888'; }

// ── CANVAS SETUP ─────────────────────────────────────────────

const root   = document.getElementById('brain-root') as HTMLDivElement;
const canvas = document.getElementById('brain-canvas') as HTMLCanvasElement;
const ctx    = canvas.getContext('2d')!;

let W = 0, H = 0, DPR = window.devicePixelRatio || 1;
let panX = 0, panY = 0, zoom = 1;
let camTargetX = 0, camTargetY = 0, camTargetZoom = 1, camAnimating = false;

function resize() {
  const header = document.querySelector('header') as HTMLElement;
  const hh = header ? header.offsetHeight : 56;
  W = window.innerWidth;
  H = window.innerHeight - hh;
  root.style.height = `${H}px`;
  canvas.style.width = `${W}px`;
  canvas.style.height = `${H}px`;
  DPR = window.devicePixelRatio || 1;
  canvas.width  = W * DPR;
  canvas.height = H * DPR;
  ctx.scale(DPR, DPR);
  warm();
}

window.addEventListener('resize', resize, { passive: true });

// ── INITIAL LAYOUT ───────────────────────────────────────────

function initPositions() {
  const l1 = nodes.filter(n => n.type === 'l1');
  const cx = W / 2, cy = H / 2;
  nodes.find(n => n.type === 'root')!.x = cx;
  nodes.find(n => n.type === 'root')!.y = cy;
  l1.forEach(n => {
    const a = L1_ANGLES[n.id] ?? 0;
    n.x = cx + Math.cos(a) * 190;
    n.y = cy + Math.sin(a) * 190;
  });
  nodes.filter(n => n.type === 'l2').forEach((n, i, arr) => {
    const parent = nodeById.get(n.parent!)!;
    const siblings = arr.filter(s => s.parent === n.parent);
    const si = siblings.indexOf(n);
    const pa = Math.atan2(parent.y - cy, parent.x - cx);
    const spread = 1.1;
    const a = pa + (si - (siblings.length - 1) / 2) * spread;
    n.x = parent.x + Math.cos(a) * 130;
    n.y = parent.y + Math.sin(a) * 130;
  });
}

// ── FORCE SIMULATION ─────────────────────────────────────────

let alpha = 0;
let rafId = 0;

function nodeCharge(n: SimNode) {
  if (n.type === 'root') return 800;
  if (n.type === 'l1')   return 260;
  return 120;
}

function tick() {
  const physicsOn = alpha >= 0.001;
  if (!physicsOn && !camAnimating) return;

  if (physicsOn) alpha *= 0.978;

  if (physicsOn) {
    // Spring forces (links)
    for (const lk of links) {
      const s = lk.source, t = lk.target;
      const dx = t.x - s.x, dy = t.y - s.y;
      const d = Math.sqrt(dx * dx + dy * dy) || 1;
      const f = (d - lk.dist) / d * lk.w * alpha;
      if (s.fx === undefined) { s.vx += dx * f; s.vy += dy * f; }
      if (t.fx === undefined) { t.vx -= dx * f; t.vy -= dy * f; }
    }

    // Repulsion (many-body)
    for (let i = 0; i < nodes.length; i++) {
      for (let j = i + 1; j < nodes.length; j++) {
        const a = nodes[i], b = nodes[j];
        const dx = b.x - a.x, dy = b.y - a.y;
        const d2 = dx * dx + dy * dy || 0.01;
        const str = (nodeCharge(a) + nodeCharge(b)) / d2 * alpha;
        if (a.fx === undefined) { a.vx -= dx * str; a.vy -= dy * str; }
        if (b.fx === undefined) { b.vx += dx * str; b.vy += dy * str; }
      }
    }

    // Centering
    let mcx = 0, mcy = 0;
    nodes.forEach(n => { mcx += n.x; mcy += n.y; });
    mcx /= nodes.length; mcy /= nodes.length;
    const tcx = W / 2, tcy = H / 2;
    nodes.forEach(n => {
      if (n.fx === undefined) {
        n.vx += (tcx - mcx) * 0.08 * alpha;
        n.vy += (tcy - mcy) * 0.08 * alpha;
      }
    });

    // Integrate
    const MAX_V = 22;
    nodes.forEach(n => {
      if (n.fx !== undefined) { n.x = n.fx; n.y = n.fy!; return; }
      n.vx = Math.max(-MAX_V, Math.min(MAX_V, n.vx * 0.84));
      n.vy = Math.max(-MAX_V, Math.min(MAX_V, n.vy * 0.84));
      n.x += n.vx;
      n.y += n.vy;
    });
  }

  // Camera lerp
  if (camAnimating) {
    const lf = 0.1;
    panX += (camTargetX - panX) * lf;
    panY += (camTargetY - panY) * lf;
    zoom += (camTargetZoom - zoom) * lf;
    if (Math.abs(panX - camTargetX) < 0.4 &&
        Math.abs(panY - camTargetY) < 0.4 &&
        Math.abs(zoom - camTargetZoom) < 0.004) {
      panX = camTargetX; panY = camTargetY; zoom = camTargetZoom;
      camAnimating = false;
    }
  }

  draw();
  rafId = requestAnimationFrame(tick);
}

function start() {
  alpha = 1;
  cancelAnimationFrame(rafId);
  rafId = requestAnimationFrame(tick);
}

function warm() {
  if (alpha < 0.35) alpha = 0.35;
  cancelAnimationFrame(rafId);
  rafId = requestAnimationFrame(tick);
}

function ensureRunning() {
  if (alpha < 0.05) alpha = 0.05;
  cancelAnimationFrame(rafId);
  rafId = requestAnimationFrame(tick);
}

function focusOn(n: SimNode) {
  const z = 1.65;
  camTargetZoom = z;
  camTargetX = W / 2 - n.x * z;
  camTargetY = H / 2 - n.y * z;
  camAnimating = true;
  ensureRunning();
}

function focusOut() {
  camTargetZoom = 1;
  camTargetX = 0;
  camTargetY = 0;
  camAnimating = true;
  ensureRunning();
}

// ── RENDERING ────────────────────────────────────────────────

let hoveredNode: SimNode | null = null;
let selectedNode: SimNode | null = null;
let timelineMode = false;
let timelineYear = 2027;

function nodeVisible(n: SimNode): number {
  if (!timelineMode) return 1;
  const id = n.type === 'l2' ? (n.parent ?? n.id) : n.id;
  const yr = TL_YEAR[id] ?? 2021;
  return yr <= timelineYear ? 1 : 0;
}

function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#0b0b0b';
  ctx.fillRect(0, 0, W, H);

  ctx.save();
  ctx.translate(panX, panY);
  ctx.scale(zoom, zoom);

  // Links
  for (const lk of links) {
    const s = lk.source, t = lk.target;
    if (!s.x && !s.y && !t.x && !t.y) continue;
    const vis = Math.min(nodeVisible(s), nodeVisible(t));
    const isHL = selectedNode &&
      (s === selectedNode || t === selectedNode ||
       s.parent === selectedNode.id || t.parent === selectedNode.id);
    ctx.beginPath();
    ctx.moveTo(s.x, s.y);
    ctx.lineTo(t.x, t.y);
    ctx.strokeStyle = isHL
      ? `rgba(220,220,220,${0.55 * vis})`
      : `rgba(255,255,255,${0.28 * vis})`;
    ctx.lineWidth = isHL ? 0.9 : 0.5;
    ctx.stroke();
  }

  // Nodes
  for (const n of nodes) {
    const st = NSTYLE[n.type];
    const vis = nodeVisible(n);
    const isHov = n === hoveredNode;
    const isSel = n === selectedNode;
    const isCon = !!selectedNode && (n === selectedNode || isConnected(n, selectedNode));
    const dimA = selectedNode ? (isCon ? vis : vis * 0.12) : vis;

    ctx.save();
    ctx.globalAlpha = dimA;

    const col = nodeColor(n);

    // Glow
    const glowStr = isSel ? 24 : isHov ? 14 : n.type === 'root' ? 8 : 0;
    if (glowStr > 0) {
      ctx.shadowBlur = glowStr;
      ctx.shadowColor = isSel || isHov ? hexAlpha(col, 0.95) : hexAlpha(col, 0.4);
    }

    // Fill
    const r = st.r + (isHov || isSel ? 1.5 : 0);
    ctx.beginPath();
    ctx.arc(n.x, n.y, r, 0, 2 * Math.PI);
    ctx.fillStyle = isHov || isSel ? '#ffffff' : col;
    ctx.fill();

    // Ring
    ctx.shadowBlur = 0;
    ctx.beginPath();
    ctx.arc(n.x, n.y, r, 0, 2 * Math.PI);
    ctx.strokeStyle = isHov || isSel ? 'rgba(255,255,255,0.7)' : hexAlpha(col, 0.45);
    ctx.lineWidth = st.ringW;
    ctx.stroke();

    ctx.restore();

    // Label — radially away from parent (L2) or canvas centre (L1/root)
    const lines = n.label.split('\n');
    const lineH = st.fs + 3.5;
    ctx.save();
    ctx.globalAlpha = dimA * (isHov || isSel ? 1 : 0.88);
    ctx.font = `${st.fw} ${st.fs}px Inter, system-ui, sans-serif`;
    ctx.fillStyle = isHov || isSel ? '#ffffff' : (n.type === 'l2' ? hexAlpha(col, 0.88) : '#f0f0f0');
    {
      const refX = n.type === 'l2'
        ? (nodeById.get(n.parent!)?.x ?? W / 2)
        : W / 2;
      const refY = n.type === 'l2'
        ? (nodeById.get(n.parent!)?.y ?? H / 2)
        : H / 2;
      const dx = n.x - refX, dy = n.y - refY;
      const len = Math.sqrt(dx * dx + dy * dy) || 1;
      const nx = dx / len, ny = dy / len;
      const pad = st.r + (isHov || isSel ? 8 : 6);
      const lbx = n.x + nx * pad;
      const lby = n.y + ny * pad;
      ctx.textAlign = nx > 0.35 ? 'left' : nx < -0.35 ? 'right' : 'center';
      ctx.textBaseline = ny >= 0 ? 'top' : 'bottom';
      const sign = ny >= 0 ? 1 : -1;
      lines.forEach((ln, i) => ctx.fillText(ln, lbx, lby + i * lineH * sign));
    }
    ctx.restore();
  }

  ctx.restore();
}

// ── HIT TEST ─────────────────────────────────────────────────

function toGraph(sx: number, sy: number): [number, number] {
  return [(sx - panX) / zoom, (sy - panY) / zoom];
}

function hitTest(gx: number, gy: number): SimNode | null {
  let best: SimNode | null = null;
  let bestD = Infinity;
  for (const n of nodes) {
    if (nodeVisible(n) === 0) continue;
    const dx = n.x - gx, dy = n.y - gy;
    const d = Math.sqrt(dx * dx + dy * dy);
    const st = NSTYLE[n.type];
    if (d < st.r + 10 && d < bestD) { best = n; bestD = d; }
  }
  return best;
}

// ── POINTER EVENTS ───────────────────────────────────────────

let dragNode: SimNode | null = null;
let pointerStartX = 0, pointerStartY = 0;
let panStartX = 0, panStartY = 0;
let isPanning = false;

canvas.addEventListener('wheel', e => {
  e.preventDefault();
  const f = e.deltaY < 0 ? 1.12 : 0.89;
  const cx = e.offsetX, cy = e.offsetY;
  panX = cx - (cx - panX) * f;
  panY = cy - (cy - panY) * f;
  zoom = Math.max(0.18, Math.min(5, zoom * f));
  draw();
}, { passive: false });

canvas.addEventListener('mousedown', e => {
  pointerStartX = e.offsetX;
  pointerStartY = e.offsetY;
  const [gx, gy] = toGraph(e.offsetX, e.offsetY);
  dragNode = hitTest(gx, gy);
  if (dragNode) {
    dragNode.fx = dragNode.x;
    dragNode.fy = dragNode.y;
    warm();
  } else {
    isPanning = true;
    panStartX = e.offsetX - panX;
    panStartY = e.offsetY - panY;
  }
});

window.addEventListener('mousemove', e => {
  const rect = canvas.getBoundingClientRect();
  const mx = e.clientX - rect.left;
  const my = e.clientY - rect.top;
  if (dragNode) {
    const [gx, gy] = toGraph(mx, my);
    dragNode.fx = gx;
    dragNode.fy = gy;
  } else if (isPanning) {
    panX = mx - panStartX;
    panY = my - panStartY;
    draw();
    canvas.style.cursor = 'grabbing';
  } else if (mx >= 0 && mx <= W && my >= 0 && my <= H) {
    const [gx, gy] = toGraph(mx, my);
    const node = hitTest(gx, gy);
    if (node !== hoveredNode) {
      hoveredNode = node;
      canvas.style.cursor = node ? 'pointer' : 'grab';
      draw();
    }
  }
});

window.addEventListener('mouseup', e => {
  const rect = canvas.getBoundingClientRect();
  const mx = e.clientX - rect.left;
  const my = e.clientY - rect.top;
  const moved = Math.hypot(mx - pointerStartX, my - pointerStartY);

  if (dragNode) {
    if (moved < 6) {
      selectedNode === dragNode ? deselect() : select(dragNode);
    }
    dragNode.fx = undefined;
    dragNode.fy = undefined;
    alpha = Math.max(alpha, 0.1);
    dragNode = null;
  } else if (isPanning) {
    isPanning = false;
    canvas.style.cursor = 'grab';
    if (moved < 4 && selectedNode) deselect();
  }
});

// Touch
let touchStartX = 0, touchStartY = 0;
let pinchDist = 0;

canvas.addEventListener('touchstart', e => {
  e.preventDefault();
  if (e.touches.length === 1) {
    const t = e.touches[0];
    const r = canvas.getBoundingClientRect();
    touchStartX = t.clientX - r.left;
    touchStartY = t.clientY - r.top;
    pointerStartX = touchStartX;
    pointerStartY = touchStartY;
    const [gx, gy] = toGraph(touchStartX, touchStartY);
    dragNode = hitTest(gx, gy);
    if (dragNode) { dragNode.fx = dragNode.x; dragNode.fy = dragNode.y; warm(); }
    else { isPanning = true; panStartX = touchStartX - panX; panStartY = touchStartY - panY; }
  } else if (e.touches.length === 2) {
    const dx = e.touches[0].clientX - e.touches[1].clientX;
    const dy = e.touches[0].clientY - e.touches[1].clientY;
    pinchDist = Math.sqrt(dx*dx + dy*dy);
    isPanning = false;
  }
}, { passive: false });

canvas.addEventListener('touchmove', e => {
  e.preventDefault();
  if (e.touches.length === 1) {
    const t = e.touches[0];
    const r = canvas.getBoundingClientRect();
    const mx = t.clientX - r.left, my = t.clientY - r.top;
    if (dragNode) {
      const [gx, gy] = toGraph(mx, my);
      dragNode.fx = gx; dragNode.fy = gy;
    } else if (isPanning) {
      panX = mx - panStartX; panY = my - panStartY; draw();
    }
  } else if (e.touches.length === 2 && pinchDist > 0) {
    const dx = e.touches[0].clientX - e.touches[1].clientX;
    const dy = e.touches[0].clientY - e.touches[1].clientY;
    const d = Math.sqrt(dx*dx + dy*dy);
    const f = d / pinchDist;
    const cx = (e.touches[0].clientX + e.touches[1].clientX) / 2 - canvas.getBoundingClientRect().left;
    const cy = (e.touches[0].clientY + e.touches[1].clientY) / 2 - canvas.getBoundingClientRect().top;
    panX = cx - (cx - panX) * f;
    panY = cy - (cy - panY) * f;
    zoom = Math.max(0.18, Math.min(5, zoom * f));
    pinchDist = d;
    draw();
  }
}, { passive: false });

canvas.addEventListener('touchend', e => {
  e.preventDefault();
  const t = e.changedTouches[0];
  const r = canvas.getBoundingClientRect();
  const mx = t.clientX - r.left, my = t.clientY - r.top;
  const moved = Math.hypot(mx - pointerStartX, my - pointerStartY);
  if (dragNode) {
    if (moved < 10) selectedNode === dragNode ? deselect() : select(dragNode);
    dragNode.fx = undefined; dragNode.fy = undefined;
    dragNode = null;
  } else { isPanning = false; if (moved < 6 && selectedNode) deselect(); }
  pinchDist = 0;
}, { passive: false });

// ── PANEL ────────────────────────────────────────────────────

const panel     = document.getElementById('side-panel')!;
const pTitle    = document.getElementById('panel-title')!;
const pBody     = document.getElementById('panel-body')!;
const pClose    = document.getElementById('panel-close')!;

pClose.addEventListener('click', deselect);

function select(n: SimNode) {
  selectedNode = n;

  // Push connected nodes outward + nudge tout le graphe
  for (const adj of nodes) {
    if (adj === n) continue;
    const dx = adj.x - n.x, dy = adj.y - n.y;
    const d = Math.sqrt(dx * dx + dy * dy) || 1;
    const str = isConnected(adj, n) ? 10 : 2;
    adj.vx += (dx / d) * str;
    adj.vy += (dy / d) * str;
  }
  alpha = Math.max(alpha, 0.7);
  cancelAnimationFrame(rafId);
  rafId = requestAnimationFrame(tick);
  focusOn(n);

  const c = CONTENT[n.id];
  const col = nodeColor(n);
  pTitle.textContent = c?.title ?? n.label.replace(/\n/g,' ');
  (pTitle as HTMLElement).style.color = col;

  let html = '';
  if (c?.body) html += `<p class="desc">${c.body}</p>`;
  if (c?.experience) html += `<p class="desc" style="font-style:italic;border-left:2px solid ${col}33;padding-left:0.75rem">${c.experience}</p>`;
  if (c?.books?.length)     html += `<span class="cat">Lectures</span><ul>${c.books.map(b=>`<li>${b}</li>`).join('')}</ul>`;
  if (c?.thinkers?.length)  html += `<span class="cat">Penseurs</span><ul>${c.thinkers.map(t=>`<li>${t}</li>`).join('')}</ul>`;
  if (c?.research?.length)  html += `<span class="cat">Recherche</span><ul>${c.research.map(r=>`<li>${r}</li>`).join('')}</ul>`;
  if (c?.questions?.length) html += `<span class="cat">Questions ouvertes</span><ul>${c.questions.map(q=>`<li>${q}</li>`).join('')}</ul>`;
  if (!c) {
    const parentNode = nodeById.get(n.parent ?? '');
    const parentContent = parentNode ? CONTENT[parentNode.id] : null;
    html = `<p class="desc">Sous-thème de <em>${parentContent?.title ?? n.parent ?? ''}</em>.</p>`;
  }
  // Connexions transversales
  const conns = LINK_DEFS.filter(l =>
    (l.source === n.id || l.target === n.id) && l.label &&
    l.source !== 'root' && l.target !== 'root'
  );
  if (conns.length > 0) {
    html += `<span class="cat">Connexions</span><ul>` +
      conns.map(l => {
        const other = l.source === n.id ? l.target : l.source;
        const otherContent = CONTENT[other];
        const otherName = otherContent?.title ?? other;
        return `<li><strong style="color:${COLORS[other] ?? '#aaa'}">${otherName}</strong> — ${l.label}</li>`;
      }).join('') + `</ul>`;
  }

  pBody.innerHTML = html;
  panel.classList.add('open');
  panel.setAttribute('aria-hidden','false');
  draw();
}

function deselect() {
  selectedNode = null;
  (pTitle as HTMLElement).style.color = '';
  panel.classList.remove('open');
  panel.setAttribute('aria-hidden','true');
  focusOut();
}

// ── RANDOM THOUGHT ───────────────────────────────────────────

const thoughtBox  = document.getElementById('thought-box')!;
const thoughtText = document.getElementById('thought-text')!;
let thoughtTimer = 0;

document.getElementById('btn-thought')!.addEventListener('click', () => {
  const t = THOUGHTS[Math.floor(Math.random() * THOUGHTS.length)];
  thoughtText.textContent = `« ${t} »`;
  thoughtBox.hidden = false;
  clearTimeout(thoughtTimer);
  thoughtTimer = window.setTimeout(() => { thoughtBox.hidden = true; }, 6000);
});
thoughtBox.addEventListener('click', () => { thoughtBox.hidden = true; clearTimeout(thoughtTimer); });

// ── TIMELINE ─────────────────────────────────────────────────


const btnTL   = document.getElementById('btn-timeline')!;
const tlBar   = document.getElementById('timeline-bar')!;
const tlSlide = document.getElementById('tl-slider') as HTMLInputElement;
const tlYearEl  = document.getElementById('tl-year')!;
const tlLabelEl = document.getElementById('tl-label')!;
const tlPlay  = document.getElementById('tl-play')!;

function setYear(yr: number) {
  timelineYear = yr;
  tlSlide.value = String(yr);
  tlYearEl.textContent = yr >= 2027 ? '2026+' : String(yr);
  tlLabelEl.textContent = TL_LABEL[yr] ?? '';
  draw();
}

btnTL.addEventListener('click', () => {
  timelineMode = !timelineMode;
  tlBar.hidden = !timelineMode;
  btnTL.classList.toggle('active', timelineMode);
  if (timelineMode) setYear(2021);
  else { timelineYear = 2027; draw(); }
});

tlSlide.addEventListener('input', () => setYear(parseInt(tlSlide.value)));

let playTimer = 0;
const PLAY_YEARS = [2021, 2023, 2024, 2025, 2026, 2027];

tlPlay.addEventListener('click', () => {
  clearInterval(playTimer);
  setYear(2021);
  tlPlay.textContent = '■';
  let idx = 0;
  playTimer = window.setInterval(() => {
    idx++;
    if (idx >= PLAY_YEARS.length) {
      clearInterval(playTimer);
      tlPlay.textContent = '▶';
      return;
    }
    setYear(PLAY_YEARS[idx]);
  }, 1100);
});

// ── BOOT ─────────────────────────────────────────────────────

document.fonts.ready.then(() => {
  resize();
  initPositions();
  start();
});

</script>

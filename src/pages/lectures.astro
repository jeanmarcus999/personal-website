---
import BaseLayout from '../layouts/BaseLayout.astro';

const months: Array<{
  label: string;
  entries: Array<{ author: string; title: string; year: number; note: string }>;
}> = [
  { label: 'Juin 2026',  entries: [] },
  { label: 'Mai 2026',   entries: [] },
  { label: 'Avril 2026', entries: [] },
];
---

<BaseLayout
  title="Lectures"
  description="Sélection mensuelle de lectures recommandées par Jean Marcus."
>
  <div class="page-wrapper">
    <h1 class="page-title">Lectures</h1>
    <p class="font-serif text-[0.95rem] sm:text-[1rem] text-muted leading-relaxed mb-12 sm:mb-14">
      Une sélection mensuelle de livres que je recommande. Mise à jour chaque mois.
    </p>
    {months.map(month => (
      <section class="mb-10">
        <span class="section-label">{month.label}</span>
        {month.entries.length === 0 ? (
          <div class="parcours-row">
            <span class="meta"></span>
            <p class="font-serif text-[0.95rem] text-muted italic mt-0 mb-0">À compléter.</p>
          </div>
        ) : (
          <div>
            {month.entries.map(e => (
              <div class="parcours-row">
                <span class="meta">{e.year}</span>
                <div>
                  <p class="font-serif text-[1rem] sm:text-[1.05rem] font-medium text-ink leading-snug mb-1 mt-0">
                    {e.author}, <em>{e.title}</em>
                  </p>
                  <p class="font-serif text-[0.9rem] sm:text-[0.95rem] text-muted leading-relaxed mt-0 mb-0">
                    {e.note}
                  </p>
                </div>
              </div>
            ))}
          </div>
        )}
      </section>
    ))}
  </div>
</BaseLayout>
